<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          package="com.yourcompany.qiblavr">

    <!-- Required for GPS location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Required for internet (magnetic declination API) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Meta Quest 3 VR and passthrough features -->
    <uses-feature android:name="android.hardware.vr.headtracking" android:required="true" android:version="1" />
    <uses-feature android:name="com.oculus.feature.PASSTHROUGH" android:required="true" />

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/app_icon"
        android:allowBackup="false"
        android:requestLegacyExternalStorage="false">

        <activity
            android:name="com.unity3d.player.UnityPlayerActivity"
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen"
            android:launchMode="singleTask"
            android:configChanges="density|fontScale|keyboard|keyboardHidden|layoutDirection|locale|mnc|mcc|navigation|orientation|screenLayout|screenSize|smallestScreenSize|uiMode|touchscreen"
            android:screenOrientation="landscape"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="com.oculus.intent.category.VR" />
            </intent-filter>

            <!-- Declare passthrough feature usage -->
            <meta-data android:name="com.oculus.ossplash" android:value="true" />
            <meta-data android:name="com.oculus.handtracking.frequency" android:value="HIGH" />
            <meta-data android:name="com.oculus.handtracking.version" android:value="V2.0" />
        </activity>

        <!-- Passthrough boundary feature declaration -->
        <meta-data android:name="com.samsung.android.vr.application.mode" android:value="vr_only" />
        <meta-data android:name="com.oculus.ossplash" android:value="true" />

        <!-- Declare SDK version used -->
        <meta-data android:name="com.oculus.supportedDevices" android:value="quest3" />

        <!-- Allow network requests for the declination API -->
        <uses-library android:name="org.apache.http.legacy" android:required="false" />
    </application>

    <!-- OpenXR & Horizon OS requirements -->
    <uses-sdk android:minSdkVersion="32" android:targetSdkVersion="33" />

</manifest>
